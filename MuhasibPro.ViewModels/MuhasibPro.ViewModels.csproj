<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>MuhasibPro.ViewModels</RootNamespace>
	  <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
	  <Nullable>annotations</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
	  <UseWinUI>true</UseWinUI>
	  <Platforms>x64</Platforms>

    <!-- GitHub Actions için önemli ayarlar -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>true</IncludeBuildOutput>

    <!-- XAML ayarları -->
    <EnableDefaultXamlItems>true</EnableDefaultXamlItems>
    <EnableDefaultPageItems>true</EnableDefaultPageItems>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4948" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.7.250606001" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\MuhasibPro.Infrastructure\MuhasibPro.Infrastructure.csproj" />
  </ItemGroup>
  
</Project>